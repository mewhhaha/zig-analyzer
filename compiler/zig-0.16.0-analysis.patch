+fn analysisOverlayForFile(zcu: *Zcu, file_index: Zcu.File.Index, _: *const Zcu.File) ?*Zcu.AnalysisOverlay {
+    if (!build_options.enable_debug_extensions or !zcu.comp.debugIncremental()) return null;
+    var iterator = zcu.analysis_overlays.iterator();
+    while (iterator.next()) |entry| {
+        if (entry.value_ptr.file_index == file_index) return entry.value_ptr;
+    }
+    return null;
+}
