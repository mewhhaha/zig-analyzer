{
  "check": {
    "exclude": [".claude", "examples/diagnostics", "tmp"]
  },
  "contracts": {
    "arena-allocators": [
      "RuleRun.allocator",
      "ActionRun.allocator",
      "findingsWithShapesAndTokens.allocator",
      "parse.allocator",
      "hoverDescription.allocator",
      "cachedCompilerTypeShapes.allocator"
    ],
    "imports": [
      {
        "from": "src/rules",
        "deny": ["src/lsp_server.zig"]
      }
    ]
  },
  "lints": {
    "profile": "idiomatic",
    "correctness": "warning",
    "rules": {
      "discarded-error": "warning"
    }
  }
}
